# Dependencies
node_modules/

# Orchestrator output workspace (per-target runs; regenerable via scripts/run.mjs)
.codeweb/

# Default run.mjs workspace target (.live/<slug>): generated analysis artifacts only —
# regenerable, never tracked. The hand-written dev tools that used to live here were graduated
# prototypes and were removed in the perf-quality round (finding 28; git history keeps them).
.live/
*.before

# Bench: evaluation corpus is cloned & pinned via bench/corpus.manifest.json (large, regenerable).
# Keep the clone script + manifest; ignore the cloned repos and any scratch run dirs.
bench/corpus/*/
bench/results/*.tmp
# Reproduction run outputs from bench/run-all.mjs (_env.json, _summary.json, _reproduce.log) —
# regenerable; the committed result JSONs are the source of truth.
bench/results/_*
bench/**/.cw/

# OS / editor noise
.DS_Store
Thumbs.db
.claude/worktrees/
