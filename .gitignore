# Dependencies
node_modules/

# Orchestrator output workspace (per-target runs; regenerable via scripts/run.mjs)
.codeweb/

# Canonical dev workspace: keep the hand-written dev tools (.live/*.mjs, .live/cli-sketch/),
# ignore the generated analysis artifacts (large, regenerable, and they drift over time).
.live/runs/
.live/*.json
.live/*.html
.live/*.md
.live/*.before
*.before

# Paper: evaluation corpus is cloned & pinned via paper/corpus.manifest.json (large, regenerable).
# Keep the clone script + manifest; ignore the cloned repos and any scratch run dirs.
paper/corpus/*/
paper/results/*.tmp
paper/**/.cw/

# OS / editor noise
.DS_Store
Thumbs.db
