# Dependencies
node_modules/

# Orchestrator output workspace (per-target runs; regenerable via scripts/run.mjs)
.codeweb/

# Canonical dev workspace: keep the hand-written dev tools (.live/*.mjs, .live/cli-sketch/),
# ignore the generated analysis artifacts (large, regenerable, and they drift over time).
.live/runs/
.live/*.json
.live/*.html
.live/*.md
.live/*.before
*.before

# Bench: evaluation corpus is cloned & pinned via bench/corpus.manifest.json (large, regenerable).
# Keep the clone script + manifest; ignore the cloned repos and any scratch run dirs.
bench/corpus/*/
bench/results/*.tmp
# Reproduction run outputs from bench/run-all.mjs (_env.json, _summary.json, _reproduce.log) —
# regenerable; the committed result JSONs are the source of truth.
bench/results/_*
bench/**/.cw/

# OS / editor noise
.DS_Store
Thumbs.db
