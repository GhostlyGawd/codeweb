{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-07-09/server.schema.json",
  "name": "io.github.ghostlygawd/codeweb",
  "description": "Deterministic call/import graph of your codebase — 27 MCP tools for coding agents plus a self-contained interactive map. Zero deps, runs 100% locally, reads code and never executes it.",
  "status": "active",
  "repository": {
    "url": "https://github.com/GhostlyGawd/codeweb",
    "source": "github"
  },
  "version": "0.9.0",
  "packages": [
    {
      "registry_type": "npm",
      "registry_base_url": "https://registry.npmjs.org",
      "identifier": "@ghostlygawd/codeweb",
      "version": "0.9.0",
      "runtime_hint": "npx",
      "transport": {
        "type": "stdio"
      },
      "runtime_arguments": [
        { "type": "positional", "value": "-y", "is_required": true },
        { "type": "positional", "value": "-p", "is_required": true },
        { "type": "positional", "value": "@ghostlygawd/codeweb", "is_required": true },
        { "type": "positional", "value": "codeweb-mcp", "is_required": true }
      ]
    }
  ]
}
